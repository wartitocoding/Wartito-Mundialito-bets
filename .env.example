# JWT Secret para tokens de autenticación (OBLIGATORIO en producción)
# Genera uno con: openssl rand -hex 32
JWT_SECRET=tu-clave-secreta-super-larga-y-aleatoria-aqui

# Ruta de la base de datos SQLite.
# Local: déjalo vacío (usa ./data/bets.db).
# Railway: monta un volumen en /data y pon: DATABASE_PATH=/data/bets.db
DATABASE_PATH=

# Token admin para el sync con ESPN y el cron (recomendado)
# Genera uno con: openssl rand -hex 32
ADMIN_TOKEN=admin-secret

# API Football (opcional, legacy — el sync ahora usa ESPN sin key)
# https://rapidapi.com/api-sports/api/api-football
API_FOOTBALL_KEY=
